// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// NextAuth.js models for MongoDB
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])

  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  subscriptionTier SubscriptionTier @default(FREE)
  
  // Credit system fields
  // Balance/earned default to 0; the signup bonus is granted in exactly one place
  // (register route for email, createUser event for OAuth) so the ledger always matches.
  credits           Int      @default(0)    // Current credit balance
  totalCreditsEarned Int     @default(0)    // Lifetime credits earned (includes signup bonus)
  totalCreditsSpent  Int     @default(0)    // Lifetime credits spent
  lastCreditUpdate  DateTime @default(now()) // Last time credits were modified

  // Extension API token (opaque, random, hashed at rest, expiring). Never the user id.
  apiTokenHash      String?   // sha256 of the raw bearer token issued to the extension
  apiTokenExpiresAt DateTime? // token expiry; expired tokens are rejected

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([apiTokenHash])

  accounts         Account[]
  sessions         Session[]
  resumes          Resume[]
  tailoredResumes  TailoredResume[]
  coverLetters     CoverLetter[]
  interviewPreps   InterviewPrep[]
  mockInterviews   MockInterview[]
  videoInterviews  VideoInterview[]
  creditTransactions CreditTransaction[]
  creditPurchases    CreditPurchase[]
  targetJob          TargetJob?
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application-specific models
enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum TemplateCategory {
  MODERN
  CLASSIC
  CREATIVE
  ATS
}

model Template {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  category    TemplateCategory
  previewUrl  String?
  cssData     Json?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  resumes     Resume[]
  tailoredResumes TailoredResume[]
  coverLetters CoverLetter[]
}

model Resume {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  templateId    String   @db.ObjectId
  title         String   @default("My Resume")
  
  // Resume data stored as nested documents (perfect for MongoDB!)
  personalInfo  Json     // { fullName, email, phone, location, website, linkedin }
  summary       String?
  experience    Json     // Array of experience objects
  education     Json     // Array of education objects
  skills        Json     // Array of skill category objects
  projects      Json     // Array of project objects
  certifications Json    // Array of certification objects
  
  isPublic      Boolean  @default(false)
  
  // Tailoring metadata for AI-optimized resumes (legacy - will be moved to TailoredResume)
  originalContent    Json?    // Backup of original content before tailoring
  tailoringMetadata  Json?    // Metadata about tailoring (job info, match score, notes)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      Template @relation(fields: [templateId], references: [id])
  tailoredVersions TailoredResume[] // All tailored versions of this base resume

  @@index([userId, updatedAt])
  @@index([templateId])
}

model TailoredResume {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  baseResumeId  String   @db.ObjectId  // Reference to the original resume
  templateId    String   @db.ObjectId
  title         String   // e.g., "Resume for Full Stack Developer at Google"
  
  // Job details for this tailored version
  jobTitle      String
  companyName   String
  jobDescription String
  
  // Resume data (same structure as Resume model)
  personalInfo  Json     // { fullName, email, phone, location, website, linkedin }
  summary       String?
  experience    Json     // Array of experience objects
  education     Json     // Array of education objects
  skills        Json     // Array of skill category objects
  projects      Json     // Array of project objects
  certifications Json    // Array of certification objects
  
  // Tailoring metadata and analytics
  tailoringMetadata Json? // ATS scores, detailed changes, keyword analysis, etc.
  matchScore    Int?     // Overall match score (0-100)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseResume    Resume   @relation(fields: [baseResumeId], references: [id], onDelete: Cascade)
  template      Template @relation(fields: [templateId], references: [id])

  @@index([userId, updatedAt])
  @@index([baseResumeId])
}

model CoverLetter {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  templateId    String   @db.ObjectId
  title         String   @default("My Cover Letter")
  
  // Cover letter data as nested documents
  jobDetails    Json     // { jobTitle, companyName, hiringManager, jobDescription }
  personalInfo  Json     // { fullName, email, phone, address }
  content       Json     // { opening, body, closing }
  tone          String   @default("professional")
  
  isPublic      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      Template @relation(fields: [templateId], references: [id])

  @@index([userId, updatedAt])
}

// Interview Preparation Models
model InterviewPrep {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  title         String   // e.g., "Software Engineer at Google"
  
  // Job details
  companyName   String
  jobTitle      String
  jobDescription String
  industry      String?
  experienceLevel String @default("mid") // entry, mid, senior, executive
  
  // Generated content
  questions     Json     // Array of PracticeQuestion objects
  companyResearch Json?  // CompanyResearch object
  behavioralCoaching Json? // BehavioralCoaching object
  
  // Metadata
  questionsGenerated Boolean @default(false)
  researchCompleted Boolean @default(false)
  coachingLoaded Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockInterviews MockInterview[]
  videoInterviews VideoInterview[]

  @@index([userId, updatedAt])
}

model MockInterview {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  interviewPrepId String @db.ObjectId
  
  // Session details
  sessionId     String   @unique
  title         String   // e.g., "Mock Interview #1 - Software Engineer"
  status        String   @default("active") // active, completed, paused
  
  // Interview configuration
  questions     Json     // Array of selected questions for this mock interview
  currentQuestionIndex Int @default(0)
  
  // Timing
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  totalTime     Int?     // Total time in seconds
  
  // Results and analysis
  overallScore  Int?     // 0-100
  summary       Json?    // MockInterviewSummary object
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewPrep InterviewPrep @relation(fields: [interviewPrepId], references: [id], onDelete: Cascade)
  answers       InterviewAnswer[]

  @@index([userId, createdAt])
  @@index([interviewPrepId, userId])
}

model InterviewAnswer {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  mockInterviewId String @db.ObjectId
  
  // Question and answer details
  questionId    String   // ID of the question from the practice questions
  question      String   // The actual question text
  answer        String   // User's answer
  category      String   // job-specific, field-related, behavioral
  difficulty    String   // easy, medium, hard
  
  // AI Analysis and feedback
  score         Int      // 0-100 score for this answer
  feedback      Json     // AnswerFeedback object with detailed analysis
  timeSpent     Int      // Time spent on this question in seconds
  
  // STAR framework analysis
  starAnalysis  Json     // Detailed STAR framework breakdown
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mockInterview MockInterview @relation(fields: [mockInterviewId], references: [id], onDelete: Cascade)

  @@index([mockInterviewId])
}

// Video Interview Models
model VideoInterview {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  interviewPrepId String? @db.ObjectId // Optional - can be standalone
  
  // Session details
  sessionId     String   @unique
  title         String   // e.g., "Video Interview - Software Engineer at Google"
  status        String   @default("scheduled") // scheduled, active, completed, cancelled
  type          String   @default("practice") // practice, mock, assessment
  
  // Job context
  jobTitle      String
  companyName   String
  jobDescription String?
  
  // Interview configuration
  questions     Json     // Array of questions for this interview
  currentQuestionIndex Int @default(0)
  aiPersonality String   @default("professional") // professional, friendly, challenging
  
  // Media and recording
  recordingUrl  String?  // URL to recorded video
  recordingStatus String @default("none") // none, recording, processing, completed, failed
  recordingDuration Int? // Duration in seconds
  
  // Timing
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  totalTime     Int?     // Total time in seconds
  
  // Real-time session data
  connectionStatus String @default("disconnected") // disconnected, connecting, connected
  lastActivity  DateTime @default(now())

  // Credits are charged when the realtime session is actually issued a token
  // (not at record creation), so a session that never starts is never billed.
  creditTransactionId String? @db.ObjectId
  
  // Results and analysis
  overallScore  Int?     // 0-100
  confidenceScore Int?   // 0-100
  engagementScore Int?   // 0-100
  deliveryScore Int?     // 0-100
  contentScore  Int?     // 0-100
  
  // Analysis data
  transcriptionData Json? // Full conversation transcript
  analyticsData Json?    // Detailed analytics (voice, facial, etc.)
  feedback      Json?    // AI-generated feedback and recommendations
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewPrep InterviewPrep? @relation(fields: [interviewPrepId], references: [id], onDelete: SetNull)
  responses     VideoInterviewResponse[]
  analytics     VideoInterviewAnalytics[]

  @@index([userId, createdAt])
  @@index([interviewPrepId])
}

model VideoInterviewResponse {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  videoInterviewId String @db.ObjectId
  
  // Question and response details
  questionId    String   // ID of the question
  questionText  String   // The actual question text
  questionOrder Int      // Order in the interview
  
  // Response data
  responseText  String?  // Transcribed response
  responseAudio String?  // Audio file URL
  responseVideo String?  // Video segment URL
  
  // Timing
  questionStartTime Int  // Seconds from interview start
  responseStartTime Int? // Seconds from interview start
  responseEndTime   Int? // Seconds from interview start
  thinkingTime      Int? // Time before starting to respond
  responseTime      Int? // Duration of response
  
  // Analysis
  confidence    Float?   // Confidence level 0-1
  clarity       Float?   // Speech clarity 0-1
  engagement    Float?   // Engagement level 0-1
  stressLevel   Float?   // Detected stress 0-1
  
  // AI evaluation
  contentScore  Int?     // 0-100
  deliveryScore Int?     // 0-100
  starScore     Int?     // STAR framework adherence 0-100
  feedback      Json?    // Detailed feedback object
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  videoInterview VideoInterview @relation(fields: [videoInterviewId], references: [id], onDelete: Cascade)

  @@index([videoInterviewId])
}

model VideoInterviewAnalytics {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  videoInterviewId String @db.ObjectId
  
  // Analytics type
  type          String   // audio, facial, posture, overall
  timestamp     Int      // Seconds from interview start
  
  // Audio analytics
  volume        Float?   // Audio volume level
  pitch         Float?   // Voice pitch
  pace          Float?   // Speaking pace (words per minute)
  pauseCount    Int?     // Number of pauses
  fillerWords   Int?     // Number of filler words
  
  // Facial analytics
  emotion       String?  // Detected emotion
  confidence    Float?   // Facial confidence 0-1
  eyeContact    Float?   // Eye contact percentage 0-1
  smileIntensity Float?  // Smile intensity 0-1
  
  // Posture analytics
  posture       String?  // Posture classification
  gestureCount  Int?     // Number of gestures
  movementLevel Float?   // Movement/fidgeting level 0-1
  
  // Engagement metrics
  attention     Float?   // Attention level 0-1
  engagement    Float?   // Overall engagement 0-1
  
  // Raw data
  rawData       Json?    // Raw analytics data for detailed analysis
  
  createdAt     DateTime @default(now())

  videoInterview VideoInterview @relation(fields: [videoInterviewId], references: [id], onDelete: Cascade)

  @@index([videoInterviewId, timestamp])
}



// Progress tracking and analytics
model InterviewProgress {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId @unique
  
  // Overall statistics
  totalSessions Int      @default(0)
  totalQuestions Int     @default(0)
  averageScore  Float    @default(0.0)
  confidenceScore Int    @default(0)
  
  // Improvement tracking
  strengths     Json     // Array of identified strengths
  improvementAreas Json  // Array of areas needing improvement
  
  // Weekly progress data
  weeklyStats   Json     // Array of weekly progress objects
  
  // Last activity
  lastSessionDate DateTime?
  lastUpdated   DateTime @updatedAt
  
  createdAt     DateTime @default(now())

  @@map("interview_progress")
}

// Credit System Models
model CreditTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  type        CreditTransactionType
  amount      Int      // Positive = earned, Negative = spent
  description String   // Human-readable description
  
  // Reference to what action triggered this transaction
  referenceId   String?  // ID of resume, interview, purchase, etc.
  referenceType String?  // "resume", "video_interview", "cover_letter", "purchase", etc.
  
  // Audit fields
  balanceAfter    Int     // User's credit balance after this transaction
  balanceBefore   Int     // User's credit balance before this transaction
  isReversed      Boolean @default(false) // For refunds/corrections
  reversalId      String? // Reference to the transaction that reverses this one
  
  // Metadata for additional context
  metadata      Json?    // Store additional context like job details, pricing info, etc.
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([referenceId, referenceType])
}

model CreditPurchase {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  
  // Purchase details
  packageType     String   // "starter", "value", "premium", "pro", "enterprise"
  creditsAmount   Int      // Credits purchased
  dollarAmount    Float    // Amount paid in dollars (e.g., 5.00, 10.00)
  creditsPerDollar Float   // Rate at time of purchase (e.g., 10.0 for 10¢ per credit)
  
  // Payment processing
  paymentProvider String   // "stripe", "paypal", etc.
  paymentIntentId String?  // External payment intent ID (for legacy purchases)
  checkoutSessionId String? // Stripe checkout session ID (for new purchases)
  paymentId       String?  // External payment ID (after completion)
  status          CreditPurchaseStatus @default(PENDING)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime? // When payment was successfully processed
  failedAt        DateTime? // When payment failed (if applicable)
  
  // Error handling
  errorMessage    String?  // Error message if payment failed
  retryCount      Int      @default(0) // Number of retry attempts
  
  // Metadata for audit trail
  purchaseMetadata Json?   // Store payment details, IP, user agent, etc.
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([paymentIntentId])
  @@index([paymentId])
  @@index([checkoutSessionId])
  @@index([status, createdAt])
}

/// The job the user is currently chasing — the spine of the whole product.
///
/// The design's core thesis: one job description is entered once and flows through
/// every AI tool. Previously each tool asked for the job again, which is why the app
/// felt like eight disconnected utilities rather than one journey.
///
/// Journey progress is DERIVED from the artifact ids below rather than stored as
/// separate booleans, so the stepper can never claim a step is done when the thing
/// it produced doesn't exist.
model TargetJob {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  userId      String  @unique @db.ObjectId // one active target job per user
  role        String
  company     String
  description String?

  /// Key requirements pulled from the posting; shown as chips in the job strip.
  requirements String[]

  // Artifacts produced for this job. Presence == that step is complete.
  baseResumeId     String? @db.ObjectId
  tailoredResumeId String? @db.ObjectId
  coverLetterId    String? @db.ObjectId
  interviewPrepId  String? @db.ObjectId
  videoInterviewId String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // userId is already @unique, which creates its index.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Durable record of every Stripe webhook event we have acted on.
/// Stripe delivers at-least-once, so without this a retried or duplicated delivery
/// could apply the same side effect twice.
model ProcessedStripeEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @unique // Stripe's event.id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// Enums for credit system
enum CreditTransactionType {
  // Credit earning events
  EARNED_SIGNUP           // Initial signup bonus
  EARNED_EMAIL_VERIFICATION // Email verification bonus
  EARNED_REFERRAL         // Referral bonus
  EARNED_PURCHASE         // Credits purchased
  EARNED_ADMIN            // Admin granted credits
  EARNED_PROMOTION        // Promotional credits
  
  // Credit spending events
  SPENT_VIDEO_INTERVIEW   // Video interview session
  SPENT_TEXT_INTERVIEW    // Text interview prep
  SPENT_RESUME_BUILDER    // Resume creation/editing
  SPENT_RESUME_TAILORING  // Resume tailoring
  SPENT_COVER_LETTER      // Cover letter generation
  
  // Credit refund events
  REFUND_RESUME_DELETE    // Refund when resume deleted
  REFUND_FAILED_OPERATION // Refund when operation fails
  REFUND_ADMIN           // Admin refund
  CLAWBACK_REFUND        // Credits removed because the payment was refunded or disputed
}

enum CreditPurchaseStatus {
  PENDING     // Payment intent created, awaiting payment
  PROCESSING  // Payment being processed
  COMPLETED   // Payment successful, credits added
  FAILED      // Payment failed
  CANCELLED   // Payment cancelled by user
  REFUNDED    // Payment refunded
}
